/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "paths": {
      "alerts": [
        "./dist/alerts"
      ],
      "api": [
        "./dist/api"
      ],
      "data": [
        "./dist/data"
      ],
      "f24": [
        "./dist/f24"
      ],
      "forms": [
        "./dist/forms"
      ],
      "functions": [
        "./dist/functions"
      ],
      "layout": [
        "./dist/layout"
      ]
    },
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "typeCheckHostBindings": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./projects/alerts/tsconfig.lib.json"
    },
    {
      "path": "./projects/alerts/tsconfig.spec.json"
    },
    {
      "path": "./projects/forms/tsconfig.lib.json"
    },
    {
      "path": "./projects/forms/tsconfig.spec.json"
    },
    {
      "path": "./projects/functions/tsconfig.lib.json"
    },
    {
      "path": "./projects/functions/tsconfig.spec.json"
    },
    {
      "path": "./projects/layout/tsconfig.lib.json"
    },
    {
      "path": "./projects/layout/tsconfig.spec.json"
    },
    {
      "path": "./projects/api/tsconfig.lib.json"
    },
    {
      "path": "./projects/api/tsconfig.spec.json"
    },
    {
      "path": "./projects/data/tsconfig.lib.json"
    },
    {
      "path": "./projects/data/tsconfig.spec.json"
    }
  ]
}
